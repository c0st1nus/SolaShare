# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
# Application environment. Use `test` for automated tests and `production` for deployment.
NODE_ENV=development
# HTTP port for the backend API.
PORT=3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Main PostgreSQL connection used by the backend in normal runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solashare
# Separate PostgreSQL connection for tests.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solashare_test

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Redis connection used for cache, ephemeral state, BullMQ, and websocket coordination.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth and sessions
# -----------------------------------------------------------------------------
# JWT signing secret for access and refresh token flows. Replace in any real environment.
JWT_SECRET=change-me
# Access token lifetime in seconds.
ACCESS_TOKEN_TTL_SECONDS=900
# Refresh token lifetime in days.
REFRESH_TOKEN_TTL_DAYS=30

# -----------------------------------------------------------------------------
# Telegram integration
# -----------------------------------------------------------------------------
# Optional Telegram bot token for notification or auth-related flows.
TELEGRAM_BOT_TOKEN=
# Optional Telegram bot username without the leading @.
TELEGRAM_BOT_USERNAME=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# Optional Google OAuth client ID. If any Google OAuth variable is set, all must be valid.
GOOGLE_CLIENT_ID=
# Optional Google OAuth client secret.
GOOGLE_CLIENT_SECRET=
# Optional frontend callback URL, for example http://localhost:3001/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------
# Solana RPC endpoint. Use devnet for backend-only development or localnet for on-chain work.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Solana commitment level used by backend RPC calls.
SOLANA_COMMITMENT=confirmed
# Deployed Solana program ID. Required for real on-chain transaction preparation and sync.
SOLANA_PROGRAM_ID=

# -----------------------------------------------------------------------------
# Wallet challenge / anti-replay
# -----------------------------------------------------------------------------
# Secret used for wallet challenge generation and verification. Must be at least 32 characters.
CHALLENGE_SECRET=
# Wallet challenge expiration time in seconds.
CHALLENGE_EXPIRY_SECONDS=600

# -----------------------------------------------------------------------------
# Storage / uploads
# -----------------------------------------------------------------------------
# Storage provider used by upload flows. Current backend expects `s3`.
STORAGE_PROVIDER=s3
# S3-compatible endpoint. MinIO default for local development.
S3_ENDPOINT=http://localhost:9000
# S3 region label. MinIO accepts arbitrary values; keep this stable locally.
S3_REGION=us-east-1
# Bucket used for uploaded files and private documents.
S3_BUCKET=solashare-private
# S3 access key.
S3_ACCESS_KEY=minioadmin
# S3 secret key.
S3_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# Indexing / webhook integrations
# -----------------------------------------------------------------------------
# Optional Helius API key for indexing and webhook-backed sync flows.
HELIUS_API_KEY=
# Optional shared secret for verifying incoming Helius webhooks.
HELIUS_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Frontend / browser access
# -----------------------------------------------------------------------------
# Comma-separated allowed origins for browser clients such as the local frontend.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
